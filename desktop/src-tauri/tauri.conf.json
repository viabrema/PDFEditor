{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PDF Editor",
  "version": "0.1.0",
  "identifier": "com.cma.pdfeditor",
  "build": {
    "frontendDist": "../../app/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev --prefix ../app",
    "beforeBuildCommand": "npm run build --prefix ../app"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "PDF Editor",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": false
  },
  "plugins": {}
}
