{
  "identifier": "default",
  "description": "Default permissions for PDF Editor",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    "fs:read-files",
    "fs:write-files",
    {
      "identifier": "fs:allow-read-file",
      "allow": [{ "path": "**" }]
    }
  ]
}
