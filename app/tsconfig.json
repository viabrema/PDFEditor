{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "src/blocks/**/*.js",
    "src/editor/**/*.js",
    "src/services/**/*.js",
    "src/utils/**/*.js",
    "src/ui/**/*.js",
    "vitest.config.js",
    "vitest.setup.js",
    "src/vite-env.d.ts"
  ],
  "exclude": ["**/*.test.js", "**/*.spec.js", "node_modules", "dist", "coverage"]
}
