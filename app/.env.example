# Copiar para `.env.local` (não commitar chaves reais).
# VITE_HUB_API_KEY=sua-chave-aqui
# VITE_AI_API_ORIGIN=https://hubia.cma.com.br/api
# Defaults iniciais (UI em Propriedades > IA Hub guarda preferencia no browser):
# VITE_HUB_AI_PROVIDER=openai
# VITE_HUB_AI_MODEL=gpt-4o-mini
# Gemini (GEMINI-2 / gemini): gemini-3.1-pro-preview, gemini-3.5-flash, gemini-3-flash-preview,
# gemini-3.1-flash-lite, gemini-2.5-flash

# Hub IA — URL completa do POST (tem prioridade sobre ORIGIN + PATH)
# VITE_AI_PROMPT_URL=https://hubia.cma.com.br/api/ai/prompt

# Base sem barra final (usado se não houver VITE_AI_PROMPT_URL)
# VITE_AI_API_ORIGIN=https://hubia.cma.com.br/api

# Só o path, começando com / (default no código: /ai/prompt)
# VITE_AI_PROMPT_PATH=/ai/prompt
